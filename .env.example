# CyberSim .env.example
# Copy to .env and fill in values. Never commit .env to git.

# ── AI Monitor ────────────────────────────────────────────────
GEMINI_API_KEY=your_google_ai_studio_key_here
GEMINI_MODEL=gemini-1.5-flash-latest
GEMINI_MAX_TOKENS=150
# Max 1 AI call per 10 seconds per session (free tier protection)
AI_CALL_COOLDOWN_SECONDS=10

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=cybersim
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=cybersim
POSTGRES_URL=postgresql://cybersim:change_this_password@postgres:5432/cybersim

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING
JWT_EXPIRY_HOURS=8

# ── Docker ────────────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
SCENARIO_NETWORK_PREFIX=172.20
KALI_IMAGE=cybersim-kali:latest
MAX_CONCURRENT_SESSIONS=10
CONTAINER_CPU_LIMIT=1.0
CONTAINER_MEMORY_LIMIT=512m

# ── Application ───────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost
LOG_LEVEL=INFO

# ── Scenario Credentials ──────────────────────────────────────
# SC-02 — Nexora AD Domain Controller Admin password
SC02_ADMIN_PASS=NexoraAdmin2024!

# SC-05 — Splunk password
SPLUNK_PASSWORD=cybersim123

# ── Scoring ───────────────────────────────────────────────────
HINT_L1_PENALTY=5
HINT_L2_PENALTY=10
HINT_L3_PENALTY=20
TIME_BONUS_THRESHOLD_MINUTES=120
