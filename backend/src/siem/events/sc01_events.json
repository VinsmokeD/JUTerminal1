      "severity": "LOW",
      "message": "Network reconnaissance: nmap SYN scan detected",
      "raw_log": "IDS Alert: SYN scan from {src_ip} to 172.20.1.0/24",
      "mitre_technique": "T1046",
      "cwe": "CWE-200",
      "category": "reconnaissance"
    },
    {
      "id": "sc01_recon_nmap_version",
      "trigger_pattern": "nmap\\s+.*-sV|--version-intensity",
