FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Samba4 AD Domain Controller — nexora.local
RUN apt-get update && apt-get install -y --no-install-recommends \
    samba \
    samba-ad-dc \
    winbind \
    krb5-user \
    dnsutils \
    python3 \
    python3-pip \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Domain provisioning script
COPY provision-dc.sh /provision-dc.sh
RUN chmod +x /provision-dc.sh

EXPOSE 389 636 88 445 53

CMD ["/provision-dc.sh"]
